<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/launchFragment">

    <!-- Launch  Fragment-->
    <fragment
        android:id="@+id/launchFragment"
        android:name="com.example.opcodeapp.view.LaunchFragment"
        android:label=""
        tools:layout="@layout/fragment_launch">
        <action
            android:id="@+id/action_launchFragment_to_eventListFragment"
            app:destination="@id/eventListFragment" />
        <action
            android:id="@+id/action_launchFragment_to_setupFragment"
            app:destination="@id/setupFragment" />
    </fragment>

    <!-- Setup Fragment -->
    <fragment
        android:id="@+id/setupFragment"
        android:name="com.example.opcodeapp.view.SetupFragment"
        android:label=""
        tools:layout="@layout/fragment_setup">
        <action
            android:id="@+id/action_setupFragment_to_eventListFragment"
            app:destination="@id/eventListFragment" />
    </fragment>


    <!-- Event List-->
    <fragment
        android:id="@+id/eventListFragment"
        android:name="com.example.opcodeapp.view.EventsListFragment"
        android:label=""
        tools:layout="@layout/fragment_events_list">
        <action
            android:id="@+id/action_eventListFragment_to_eventDetailsFragment"
            app:destination="@id/eventDetailsFragment" />
        <action
            android:id="@+id/action_eventListFragment_to_organizerEventFragment"
            app:destination="@id/organizerEventFragment" />
    </fragment>

    <!-- Event Details -->
    <fragment
        android:id="@+id/eventDetailsFragment"
        android:name="com.example.opcodeapp.view.EventDetailsFragment"
        android:label=""
        tools:layout="@layout/fragment_event_details">
        <argument
            android:name="event"
            app:argType="com.example.opcodeapp.model.Event" />
    </fragment>

    <!-- Event Details (For Organizer) -->
    <fragment
        android:id="@+id/organizerEventFragment"
        android:name="com.example.opcodeapp.view.OrganizerEventFragment"
        android:label=""
        tools:layout="@layout/fragment_event_organizer">

        <action
            android:id="@+id/action_FinalOrganizerEventFragment_to_EnrolledUsersFragment"
            app:destination="@id/enrolledUsersFragment" />
        <action
            android:id="@+id/action_FinalOrganizerEventFragment_to_InvitedUsersFragment"
            app:destination="@id/invitedUsersFragment" />
        <action
            android:id="@+id/action_FinalOrganizerEventFragment_to_WaitListFragment"
            app:destination="@id/waitListFragment" />
        <action
            android:id="@+id/action_FinalOrganizerEventFragment_to_CommentsFragment"
            app:destination="@id/commentsFragment" />
    </fragment>

    <fragment
        android:id="@+id/enrolledUsersFragment"
        android:name="com.example.opcodeapp.view.EnrolledUsersFragment"
        android:label=""
        tools:layout="@layout/fragment_enrolled_users" />

    <fragment
        android:id="@+id/commentsFragment"
        android:name="com.example.opcodeapp.view.CommentsFragment"
        android:label=""
        tools:layout="@layout/fragment_comments" />

    <fragment
        android:id="@+id/invitedUsersFragment"
        android:name="com.example.opcodeapp.view.InvitedUsersFragment"
        android:label=""
        tools:layout="@layout/fragment_invited_users" />

    <!-- Waitlist Fragment -->
    <fragment
        android:id="@+id/waitListFragment"
        android:name="com.example.opcodeapp.view.WaitListFragment"
        android:label=""
        tools:layout="@layout/waitlist_screen" />

    <!-- Event Creator Fragment -->
    <fragment
        android:id="@+id/eventCreatorFragment"
        android:name="com.example.opcodeapp.view.EventCreatorFragment"
        android:label=""
        tools:layout="@layout/fragment_event_creator">
        <action
            android:id="@+id/action_eventCreatorFragment_to_finalOrganizerEventFragment"
            app:destination="@id/organizerEventFragment" />
    </fragment>

    <!-- Invited Entrants Fragment -->

    <!-- Profile Fragment-->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.opcodeapp.view.ProfileFragment"
        android:label=""
        tools:layout="@layout/fragment_profile" />
</navigation>
