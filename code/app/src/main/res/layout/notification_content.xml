<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="5dp"
    android:paddingHorizontal="20dp"
    android:descendantFocusability="blocksDescendants">

    <TextView
        android:id="@+id/notification_read"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:background="@drawable/circle"
        android:padding="20dp"
        android:textAlignment="center"
        android:layout_gravity="center"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/notification_event_name"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="@string/notification_event_name"
        android:textAlignment="center"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/notification_body"
        android:layout_width="wrap_content"
        android:maxWidth="185dp"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="@string/message"
        android:textAlignment="center"
        android:textSize="15sp" />

    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1" />

    <Button
        android:id="@+id/notification_delete"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/ic_delete_icon"
        android:padding="20dp"
        android:layout_gravity="end"
        android:focusable="false"
        android:focusableInTouchMode="false" />
</LinearLayout>
